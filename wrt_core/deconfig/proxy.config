# Proxy
# ======================
# Proxy - HomeProxy (IPQ6000 推荐版)
# ======================
CONFIG_PACKAGE_luci-app-homeproxy=y

# Sing-Box 核心（强烈推荐）
CONFIG_PACKAGE_sing-box=y
CONFIG_PACKAGE_sing-box_WITH_CHACHA20_POLY1305=y
CONFIG_PACKAGE_sing-box_WITH_QUIC=y
CONFIG_PACKAGE_sing-box_WITH_UTLS=y
CONFIG_PACKAGE_sing-box_WITH_REALITY=y
CONFIG_PACKAGE_sing-box_WITH_ACME=y
CONFIG_PACKAGE_sing-box_WITH_GV2RAY=y
CONFIG_PACKAGE_sing-box_WITH_TUI=y
CONFIG_PACKAGE_sing-box_WITH_CLASH_API=y
CONFIG_PACKAGE_sing-box_WITH_ECH=y
CONFIG_PACKAGE_sing-box_WITH_QUIC_GO=y
 CONFIG_PACKAGE_sing-box_WITH_XTLS=y

# 禁用 PassWall 防止冲突
# CONFIG_PACKAGE_luci-app-passwall is not set
